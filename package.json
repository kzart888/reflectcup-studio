{
  "name": "reflectcup-studio",
  "version": "0.1.0",
  "private": false,
  "description": "A web-based reflective cup anamorphosis customizer.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "worker:build": "esbuild tools/workers/production-worker.ts tools/workers/production-job-thread.ts --bundle --platform=node --target=node24 --format=cjs --external:sharp --external:pg --external:@node-rs/argon2 --external:next --external:next/* --outdir=dist/workers --out-extension:.js=.cjs",
    "worker:production": "pnpm worker:build && node dist/workers/production-worker.cjs",
    "worker:production:once": "pnpm worker:build && node dist/workers/production-worker.cjs --once",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "pnpm worker:build && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx tools/db/migrate.ts",
    "db:seed": "tsx tools/db/seed.ts",
    "admin:create": "tsx tools/admin/create-owner.ts",
    "profile:generate": "tsx tools/optical-profile/generate.ts",
    "calibration:generate": "tsx tools/fixtures/generate-calibration.ts",
    "scene:bake": "tsx tools/scenes/generate-baked-assets.ts",
    "style:review": "tsx tools/style-lab/generate-review.ts",
    "env:init": "tsx tools/local/init-env.ts",
    "local:up": "docker compose up -d postgres",
    "local:postgres": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/local/postgres.ps1",
    "local:down": "docker compose down",
    "maintenance:expire": "tsx tools/maintenance/expire-sessions.ts",
    "maintenance:storage": "tsx tools/maintenance/drain-storage-deletions.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "drizzle-orm": "0.45.2",
    "fflate": "^0.8.2",
    "lucide-react": "^0.544.0",
    "next": "16.2.10",
    "pg": "^8.16.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.3",
    "three": "0.185.1",
    "three-stdlib": "^2.36.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.185.0",
    "drizzle-kit": "^0.31.4",
    "esbuild": "0.28.1",
    "eslint": "^9.35.0",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
